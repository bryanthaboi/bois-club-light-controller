<?xml version="1.0" encoding="UTF-8"?>
<!-- launchd LaunchAgent template. install.sh substitutes __NODE__, __DIR__, __LOG__. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.boisclub.lightcontroller</string>

  <key>ProgramArguments</key>
  <array>
    <string>__NODE__</string>
    <string>--force-node-api-uncaught-exceptions-policy=true</string>
    <string>__DIR__/index.js</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__DIR__</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
    <key>NEEWER_LOG_LEVEL</key>
    <string>info</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
    <key>Crashed</key>
    <true/>
  </dict>

  <key>ThrottleInterval</key>
  <integer>5</integer>

  <key>StandardOutPath</key>
  <string>__LOG__/boisclub.out.log</string>
  <key>StandardErrorPath</key>
  <string>__LOG__/boisclub.err.log</string>

  <key>ProcessType</key>
  <string>Interactive</string>
</dict>
</plist>
